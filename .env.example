NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key
ANTHROPIC_API_KEY=placeholder-anthropic-key
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Email — Morning Brew digest (https://resend.com — free tier: 3,000 emails/month)
RESEND_API_KEY=re_placeholder_key

# Cron security — set a random secret, add it to Vercel env vars + your scheduler
CRON_SECRET=replace-with-a-random-secret

# Demo mode — set to "true" to explore without Supabase or Anthropic accounts
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true
